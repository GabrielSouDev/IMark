@inject JwtAuthStateProvider JwtAuthStateProvider

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">IMark</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Inicio
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/Incluir" Match="NavLinkMatch.All">
                <span class="bi bi-box-arrow-left-nav-menu" aria-hidden="true"></span> Incluir Ponto
            </NavLink>
        </div>
        
        <div class="nav-item px-3">
            <NavLink class="nav-link" @onclick="LogOut" Match="NavLinkMatch.All">
                <span class="bi bi-box-arrow-left-nav-menu" aria-hidden="true"></span> Sair
            </NavLink>
        </div>
    </nav>
</div>
@code {
    private async Task LogOut()
    {
        await JwtAuthStateProvider.NotifyLogoutAsync();
        StateHasChanged();
    }
}