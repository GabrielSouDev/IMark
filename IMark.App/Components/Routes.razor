<Router AppAssembly="typeof(MauiProgram).Assembly"
        AdditionalAssemblies="new[] { typeof(IMark.Shared.Components.Pages.Home).Assembly }"
        NotFoundPage="typeof(IMark.Shared.Components.Pages.NotFound)">

    <Found Context="routeData">
        <AuthorizeRouteView RouteData="routeData" DefaultLayout="typeof(IMark.Shared.Components.Layout.MainLayout)">
            <NotAuthorized>
                <RedirectToLogin />
            </NotAuthorized>
        </AuthorizeRouteView>
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
</Router>
